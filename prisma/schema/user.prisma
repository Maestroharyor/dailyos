// User role - distinguishes merchants (DailyOS) from customers (VKT-Bougie).
// Both share one Supabase Auth pool; the role is set from signup metadata and
// written by the handle_new_user trigger (see supabase/triggers.sql).
enum UserRole {
  MERCHANT
  CUSTOMER
}

// Profile row mirroring auth.users. id == auth.users.id (UUID).
// Populated by the handle_new_user Postgres trigger, NEVER inserted by the app.
// Mapped to "profiles" (not "users") to avoid colliding with Supabase auth.users.
model User {
  id        String   @id @db.Uuid
  name      String
  email     String   @unique
  role      UserRole @default(MERCHANT)
  // Platform-level super admin. Not set by signup; granted manually (e.g. via SQL).
  // Gates cross-space operations like binding a Space to the external storefront.
  isSuperAdmin Boolean @default(false)
  image     String?
  // Last space the user actively worked in, so any browser/device resumes it.
  // Plain nullable id (no FK) so deleting a space can't break the profile row.
  lastSpaceId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Space relations
  ownedSpaces Space[]           @relation("SpaceOwner")
  memberships SpaceMember[]
  invitesSent SpaceInvitation[] @relation("InvitedBy")

  // Audit
  auditLogs AuditLog[]

  @@map("profiles")
}
